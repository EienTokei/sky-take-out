<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.EmployeeMapper">
    <!--
        pageQuery：员工分页查询
        功能：根据条件动态拼接 WHERE 子句，并按创建时间倒序排列。
        注意：分页逻辑由 PageHelper 在 Service 层通过 startPage 方法实现，
              因此此 SQL 不需要写 LIMIT 子句，PageHelper 会自动追加。
    -->
    <select id="pageQuery" resultType="com.sky.entity.Employee">
        select * from employee
        <where>
            <!-- 如果传入的 name 不为空且不为空字符串，则拼接模糊查询条件 -->
            <if test="name != null and name != ''">
                <!-- 使用数据库函数 concat 拼接前后百分号，实现包含匹配 -->
                <!-- % 匹配任意长度的任意字符（包括零个字符）
                     _ 匹配单个任意字符
                     #{name} 是 MyBatis 的预编译参数占位符
                        MyBatis 会将 #{name} 替换为 ?，并通过 PreparedStatement 的参数化查询将实际值安全地传递给数据库，不会导致 SQL 注入风险
                        MyBatis 会根据参数类型自动处理，如字符串会自动加引号
                     ${name} 是纯文本替换，直接将参数拼接到 SQL 中，存在 SQL 注入风险，一般不推荐用于用户输入
                -->
                and name like concat('%', #{name}, '%')
            </if>
        </where>
        order by create_time desc
    </select>
</mapper>
